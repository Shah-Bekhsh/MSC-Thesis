  {
    "name": "find_supply_plant",
    "description": "Find the drinking water plant(s) supplying a location.\n    Input: UTM32 EUREF89 (EPSG:25832) coordinates.\n    Always call geocode_address first when the user provides an address.\n    Returns list of plants with plantid, name, address, watertype, and active status.",
    "input_schema": {
      "properties": {
        "x_utm32": {
          "title": "X Utm32",
          "type": "number"
        },
        "y_utm32": {
          "title": "Y Utm32",
          "type": "number"
        }
      },
      "required": [
        "x_utm32",
        "y_utm32"
      ],
      "title": "find_supply_plantArguments",
      "type": "object"
    },
    "output_schema": {
      "$defs": {
        "SupplyPlantRow": {
          "properties": {
            "plantid": {
              "title": "Plantid",
              "type": "number"
            },
            "plantname": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Plantname"
            },
            "plantaddress": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Plantaddress"
            },
            "plantpostalcode": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Plantpostalcode"
            },
            "watertype": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Watertype"
            },
            "active": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Active"
            }
          },
          "required": [
            "plantid",
            "plantname",
            "plantaddress",
            "plantpostalcode",
            "watertype",
            "active"
          ],
          "title": "SupplyPlantRow",
          "type": "object"
        }
      },
      "properties": {
        "result": {
          "items": {
            "$ref": "#/$defs/SupplyPlantRow"
          },
          "title": "Result",
          "type": "array"
        }
      },
      "required": [
        "result"
      ],
      "title": "find_supply_plantOutput",
      "type": "object"
    }
  },
  {
    "name": "geocode_address",
    "description": "Convert a Danish address string to UTM32 EUREF89 (EPSG:25832) coordinates.\n    Call this whenever the user provides an address instead of coordinates.\n    Returns address, x_utm32 (easting), and y_utm32 (northing).\n    If the address cannot be found, returns an 'error' field — in that case do\n    NOT proceed with guessed coordinates; report that the address could not be located.",
    "input_schema": {
      "properties": {
        "address": {
          "title": "Address",
          "type": "string"
        }
      },
      "required": [
        "address"
      ],
      "title": "geocode_addressArguments",
      "type": "object"
    },
    "output_schema": {
      "$defs": {
        "GeocodeError": {
          "properties": {
            "error": {
              "title": "Error",
              "type": "string"
            },
            "raw_keys": {
              "items": {
                "type": "string"
              },
              "title": "Raw Keys",
              "type": "array"
            }
          },
          "required": [
            "error"
          ],
          "title": "GeocodeError",
          "type": "object"
        },
        "GeocodeSuccess": {
          "properties": {
            "address": {
              "title": "Address",
              "type": "string"
            },
            "x_utm32": {
              "title": "X Utm32",
              "type": "number"
            },
            "y_utm32": {
              "title": "Y Utm32",
              "type": "number"
            },
            "wgs84_lon": {
              "title": "Wgs84 Lon",
              "type": "number"
            },
            "wgs84_lat": {
              "title": "Wgs84 Lat",
              "type": "number"
            }
          },
          "required": [
            "address",
            "x_utm32",
            "y_utm32",
            "wgs84_lon",
            "wgs84_lat"
          ],
          "title": "GeocodeSuccess",
          "type": "object"
        }
      },
      "properties": {
        "result": {
          "anyOf": [
            {
              "$ref": "#/$defs/GeocodeSuccess"
            },
            {
              "$ref": "#/$defs/GeocodeError"
            }
          ],
          "title": "Result"
        }
      },
      "required": [
        "result"
      ],
      "title": "geocode_addressOutput",
      "type": "object"
    }
  },
  {
    "name": "get_compound_group",
    "description": "Get all compound IDs belonging to a named compound group.\n    Use this for any CLASS of substances (PFAS, pesticides, etc.) rather than\n    searching for individual compounds. Common English names and acronyms are\n    understood — e.g. get_compound_group(\"PFAS\") or get_compound_group(\"pesticides\")\n    — and are mapped internally to the Danish group terms in Jupiter, so you do\n    not need to supply the Danish name yourself. Wildcards (%) are added\n    automatically if omitted.",
    "input_schema": {
      "properties": {
        "group_name": {
          "title": "Group Name",
          "type": "string"
        }
      },
      "required": [
        "group_name"
      ],
      "title": "get_compound_groupArguments",
      "type": "object"
    },
    "output_schema": {
