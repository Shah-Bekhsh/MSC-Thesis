  {
    "name": "compare_source_to_tap",
    "description": "Compare SOURCE groundwater chemistry against TREATED tap water for a plant.\n    Returns both datasets side by side along with structured caveats.\n    IMPORTANT: this tool deliberately does NOT compute a single treatment-efficiency\n    percentage. Source values are per-borehole raw groundwater (often sampled in\n    different years), while tap values are the blended, treated plant output. A naive\n    subtraction would be scientifically misleading. Present the comparison qualitatively,\n    surfacing the caveats to the user.",
    "input_schema": {
      "properties": {
        "plantid": {
          "title": "Plantid",
          "type": "integer"
        },
        "compoundno": {
          "title": "Compoundno",
          "type": "integer"
        }
      },
      "required": [
        "plantid",
        "compoundno"
      ],
      "title": "compare_source_to_tapArguments",
      "type": "object"
    },
    "output_schema": {
      "$defs": {
        "SourceBorehole": {
