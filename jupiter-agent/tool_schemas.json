            "long_text": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Long Text"
            },
            "short_text": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Short Text"
            }
          },
          "required": [
            "compoundno",
            "long_text",
            "short_text"
          ],
          "title": "CompoundGroupRow",
          "type": "object"
        }
      },
      "properties": {
        "result": {
          "items": {
            "$ref": "#/$defs/CompoundGroupRow"
          },
          "title": "Result",
          "type": "array"
        }
      },
      "required": [
        "result"
      ],
      "title": "get_compound_groupOutput",
      "type": "object"
    }
  },
  {
    "name": "get_legal_limit",
    "description": "Get the official Danish drinking water limit for a compound.\n    Returns consumer_min, consumer_max, waterworks_max, and unit.\n    Returns an empty dict if no legal limit exists for the compound.",
    "input_schema": {
      "properties": {
        "compoundno": {
          "title": "Compoundno",
          "type": "integer"
        }
      },
      "required": [
        "compoundno"
      ],
      "title": "get_legal_limitArguments",
      "type": "object"
    },
    "output_schema": {
      "properties": {
        "compound": {
          "anyOf": [
            {
              "type": "string"
