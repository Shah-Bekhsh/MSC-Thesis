              "type": "null"
            }
          ],
          "default": null,
          "title": "Consumer Max"
        },
        "waterworks_max": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Waterworks Max"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
